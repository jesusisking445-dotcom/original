# ============================================================
# HomoDentHealth Backend — Environment Configuration
# ============================================================
# 1. Copy this file to ".env"  →   cp .env.example .env
# 2. Fill in the real values below.
# 3. NEVER commit the real ".env" file to git or include it in
#    a zip/submission — it is already excluded via .gitignore.
# ============================================================

# --- Server ---------------------------------------------------
NODE_ENV=production
PORT=4000

# --- Database (MongoDB) ----------------------------------------
# Local dev:      mongodb://127.0.0.1:27017/dentalcare
# MongoDB Atlas (free tier, recommended for hosting):
#   1. Create a free cluster at https://www.mongodb.com/cloud/atlas
#   2. Database Access → add a user + password
#   3. Network Access → allow access from anywhere (0.0.0.0/0) or your host's IP
#   4. Connect → "Drivers" → copy the connection string below
MONGODB_URI=
# --- Auth secrets -----------------------------------------------
# Generate strong random secrets, e.g. run:  openssl rand -hex 32
JWT_SECRET=replace_with_a_random_64_character_hex_string
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=replace_with_a_different_random_64_character_hex_string
REFRESH_TOKEN_EXPIRE=30d

# --- CORS ---------------------------------------------------------
# Comma-separated list of frontend origins allowed to call this API.
# Add your deployed frontend URL here once you host it
# (e.g. https://homodenthealth.netlify.app)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# --- Email (SMTP) — used for OTP verification, password reset, ----
# --- appointment confirmations -------------------------------------
# Gmail example: create an "App Password" at https://myaccount.google.com/apppasswords
# (you cannot use your normal Gmail password here)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=noreply@homodenthealth.ng

# Where contact-form submissions get emailed to (defaults to SMTP_FROM if blank)
CONTACT_INBOX_EMAIL=

# --- Account security -----------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=900000

# --- OTP verification -------------------------------------------------
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5

# --- Optional third-party APIs (not required to run the core app) ---
# Google Maps key is used by the FRONTEND, not this backend —
# add it in frontend/config.js instead (see comments in that file).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- File uploads --------------------------------------------------
FILE_UPLOAD_PATH=/uploads
MAX_FILE_SIZE=10485760

LOG_LEVEL=info
